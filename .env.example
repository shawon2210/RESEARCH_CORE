# ── RESEARCH_CORE Environment Configuration ──

# Required: MongoDB connection string
#   Docker: mongodb://mongo:27017/research-core
#   Local:  mongodb://localhost:27017/research-core
MONGODB_URI=mongodb://localhost:27017/research-core

# Optional: Public site URL (used for OG meta tags, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
